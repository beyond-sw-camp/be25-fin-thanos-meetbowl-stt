# Runtime
HOST=0.0.0.0
PORT=3000
INTERNAL_TOKEN=replace-with-local-internal-token

# OpenAI Realtime STT and Translation. Never expose this key to meetbowl-fe.
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_REALTIME_TRANSLATION_MODEL=gpt-realtime-translate
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-realtime-whisper
OPENAI_REALTIME_TRANSCRIPTION_DELAY=low
ENABLE_TRANSLATION=false

# LiveKit server participant
LIVEKIT_URL=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=replace-with-livekit-secret
LIVEKIT_AGENT_IDENTITY_PREFIX=meetbowl-stt

# RabbitMQ final transcript storage request
RABBITMQ_URL=amqp://meetbowl:local-rabbitmq-password@localhost:5672/
RABBITMQ_EXCHANGE=meetbowl.topic

# Redis Stream realtime AI feedback
REDIS_URL=redis://localhost:6379
REDIS_FEEDBACK_CONSUMER_GROUP=stt-feedback-relay
REDIS_FEEDBACK_CONSUMER_NAME=stt-local
REDIS_STREAM_MAX_LENGTH=2000

# Meetbowl segment finalization
VAD_RMS_THRESHOLD=0.015
VAD_SILENCE_MS=700
SEGMENT_NO_DELTA_TIMEOUT_MS=1200
TRANSLATION_GRACE_MS=500
MAX_SEGMENT_DURATION_MS=15000
